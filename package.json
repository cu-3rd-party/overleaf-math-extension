{
  "name": "linal-extension",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,json}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,html,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.py": [
      "black"
    ]
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.1",
    "@types/node": "^24.0.15",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.5",
    "vite-plugin-zip-pack": "^1.2.4"
  },
  "dependencies": {
    "prettier-plugin-latex": "^2.0.1",
    "pyodide": "^0.29.3",
    "vite-plugin-static-copy": "^3.2.0"
  }
}
